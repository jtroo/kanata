(defcfg
  managed-repeat yes
  managed-repeat-delay 500
  managed-repeat-interval 30
  process-unmapped-keys yes
)

(defsrc a s d f bspc del left right up down)
(deflayer base a s d f bspc del left right up down)

(defrepeat
  (bspc 300 20)
  (del  300 20)
  (left  250 25)
  (right 250 25)
  (up    250 25)
  (down  250 25)
)
